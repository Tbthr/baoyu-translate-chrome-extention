{
  "name": "baoyu-translate",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension for translating web articles with three modes (quick/normal/refined)",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "sandcastle": "npx tsx .sandcastle/main.mts"
  },
  "dependencies": {
    "defuddle": "^0.18.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.6.5",
    "@types/chrome": "^0.0.287",
    "@types/jsdom": "^28.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-static-copy": "^2.2.0",
    "vitest": "^4.1.7"
  }
}
